{
  "name": "diff-review-axi",
  "version": "0.1.0",
  "description": "Review uncommitted git diffs in a browser and hand structured comments back to an AI agent.",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "diff-review": "./bin/diff-review.js"
  },
  "files": [
    "bin",
    "dist",
    ".claude/skills"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.frontend.json --noEmit && node esbuild.frontend.mjs",
    "test": "vitest run",
    "skill:generate": "node scripts/generate-skill.mjs",
    "skill:check": "node scripts/generate-skill.mjs --check"
  },
  "dependencies": {
    "@toon-format/toon": "^2.1.0",
    "axi-sdk-js": "^0.1.8",
    "diff2html": "^3.4.56",
    "preact": "^10.29.4"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.28.1",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
